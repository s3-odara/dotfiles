{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "command": {
    "review": {
      "agent": "review_orchestrator",
      "subtask": true,
      "template": "Review input (code target, handoff file, or both): $ARGUMENTS\n"
    },
    "debug": {
      "agent": "debugger",
      "subtask": true,
      "template": "Bug investigation input (symptoms, repro command, logs, or target files): $ARGUMENTS\n"
    },
    "planner": {
      "agent": "planner",
      "subtask": true,
      "template": "Planning input (feature, bug, target files, constraints, or spec path): $ARGUMENTS\n"
    },
    "spec": {
      "agent": "specifier",
      "subtask": true,
      "template": "Specification input (feature request, problem statement, constraints, or target files): $ARGUMENTS\n"
    }
  },
  "share": "disabled",
  "autoupdate": false,
  "lsp": true,
  "formatter": true,
  "default_agent": "operator",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa",
      "headers": {
        "x-api-key": "{env:EXAAI_API_KEY}"
      },
      "enabled": true
    },
    "parallel-search": {
      "type": "remote",
      "url": "https://search.parallel.ai/mcp",
      "headers": {
        "Authorization": "Bearer {env:PARALLELAI_API_KEY}"
      },
      "enabled": true
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "specifier": {
      "description": "Specification agent that inspects relevant context and writes small, concrete, testable specs under .agents/specs.",
      "mode": "all",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": {
          "*": "deny",
          ".agents/**": "allow"
        },
        "bash": {
          "*": "deny",
          "ls*": "allow",
          "mkdir*": "allow",
          "date": "allow"
        },
        "question": "allow",
        "task": {
          "*": "allow"
        },
        "read": {
          ".agents/specs/*.md": "allow",
          ".agents/plans/*.md": "allow",
          ".agents/research/*.md": "allow"
        }
      },
      "prompt": "{file:./prompts/specifier.md}",
      "reasoningEffort": "high"
    },
    "planner": {
      "description": "Planning agent that turns user input or specs into focused implementation plans under .agents/plans.",
      "mode": "all",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": {
          "*": "deny",
          ".agents/**": "allow"
        },
        "bash": {
          "*": "deny"
        },
        "question": "allow",
        "task": {
          "*": "allow"
        },
        "read": {
          ".agents/specs/*.md": "allow",
          ".agents/plans/*.md": "allow",
          ".agents/research/*.md": "allow"
        }
      },
      "prompt": "{file:./prompts/planner.md}",
      "reasoningEffort": "high"
    },
    "plan_reviewer": {
      "description": "Read-only planning review worker that suggests focused improvements to planner drafts.",
      "mode": "subagent",
      "hidden": true,
      "model": "openai/gpt-5.4-mini",
      "permission": {
        "edit": {
          "*": "deny"
        },
        "bash": {
          "*": "deny"
        },
        "read": {
          ".agents/specs/*.md": "allow",
          ".agents/plans/*.md": "allow",
          ".agents/research/*.md": "allow"
        }
      },
      "prompt": "{file:./prompts/plan_reviewer.md}",
      "reasoningEffort": "low"
    },
    "build": {
      "disable": true
    },
    "implementer": {
      "description": "Primary implementation/validation agent with proactive best-effort delegation to testing and debugging subagents.",
      "mode": "all",
      "model": "opencode-go/kimi-k2.7-code",
      "permission": {
        "edit": {
          "*": "allow"
        },
        "external_directory": "allow",
        "task": {
          "*": "allow"
        }
      },
      "prompt": "{file:./prompts/implementer.md}",
      "reasoningEffort": "medium"
    },
    "operator": {
      "description": "Primary ops agent for system operations, troubleshooting, server provisioning, and environment setup with explicit confirmation for dangerous actions.",
      "mode": "all",
      "model": "openai/gpt-5.5",
      "permission": {
        "*": "allow",
        "doom_loop": "ask",
        "webfetch": "deny",
        "websearch": "deny"
      },
      "prompt": "{file:./prompts/operator.md}"
    },
    "delegator": {
      "description": "Primary goal orchestration agent that analyzes user goals, decomposes them into sub-tasks, and delegates execution to specialized agents.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": {
          "*": "allow"
        },
        "external_directory": "allow",
        "question": "allow",
        "task": {
          "*": "allow"
        }
      },
      "prompt": "{file:./prompts/delegator.md}",
      "reasoningEffort": "high"
    },
    "review_orchestrator": {
      "description": "Primary orchestrated reviewer for explicit code targets, canonical handoffs, or both, with exploration, optional research, multi-perspective subreviews, and report output.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": {
          "*": "deny",
          ".agents/**": "allow"
        },
        "question": "allow",
        "task": {
          "*": "allow"
        },
        "read": {
          ".agents/specs/*.md": "allow",
          ".agents/plans/*.md": "allow",
          ".agents/impl-reports/*.md": "allow",
          ".agents/research/*.md": "allow"
        }
      },
      "prompt": "{file:./prompts/review_orchestrator.md}",
      "reasoningEffort": "high"
    },
    "debugger": {
      "description": "Performs command-driven bug investigation with reproduction, root-cause analysis, and evidence-only reporting.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": {
          "*": "deny",
          ".agents/**": "allow",
          "/tmp/**": "allow"
        },
        "external_directory": {
          "/tmp/*": "allow"
        },
        "task": {
          "*": "allow"
        },
        "read": {
          "/tmp/*": "allow"
        }
      },
      "prompt": "{file:./prompts/debugger.md}",
      "reasoningEffort": "medium"
    },
    "explorer": {
      "description": "Read-only exploration agent that uses relevant skills provided by primary-agent delegation context.",
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "permission": {
        "edit": {
          "*": "deny"
        },
        "external_directory": "allow"
      },
      "prompt": "{file:./prompts/explorer.md}",
      "reasoningEffort": "medium"
    },
    "code_reviewer": {
      "description": "Read-only code review worker for review_orchestrator-orchestrated reviews. Use only when delegated by review_orchestrator; not an entrypoint for user review requests.",
      "mode": "subagent",
      "hidden": true,
      "model": "openai/gpt-5.4-mini",
      "permission": {
        "edit": {
          "*": "deny"
        },
        "task": {
          "*": "allow"
        }
      },
      "prompt": "{file:./prompts/code_reviewer.md}",
      "reasoningEffort": "medium"
    },
    "code_review_crosschecker": {
      "description": "Independent read-only code review cross-check worker using an alternate model for review_orchestrator-orchestrated reviews.",
      "mode": "subagent",
      "hidden": true,
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": {
          "*": "deny"
        }
      },
      "prompt": "{file:./prompts/code_review_crosschecker.md}",
      "reasoningEffort": "medium"
    },
    "internet_researcher": {
      "description": "Performs targeted internet research when primary planning agents have material knowledge uncertainty.",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "permission": {
        "edit": {
          "*": "deny",
          ".agents/research/**": "allow"
        },
        "webfetch": "allow",
        "websearch": "allow"
      },
      "prompt": "{file:./prompts/internet_researcher.md}",
      "reasoningEffort": "low"
    },
    "tester": {
      "description": "Read-only test runner that triages failures and writes failure-report files when suites fail.",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "permission": {
        "edit": {
          "*": "ask",
          ".agents/**": "allow",
          "/tmp/**": "allow"
        },
        "external_directory": {
          "/tmp/*": "allow"
        },
        "read": {
          "/tmp/*": "allow"
        }
      },
      "prompt": "{file:./prompts/tester.md}",
      "reasoningEffort": "medium"
    }
  },
  "experimental": {
    "mcp_timeout": 1200000
  },
  "plugin": ["./plugin/osc99-notify.ts"]
}
