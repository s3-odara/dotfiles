{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "github-copilot/gpt-5.4-mini",
  "command": {
    "review": {
      "agent": "reviewer",
      "subtask": false,
      "template": "Review target: $ARGUMENTS\n"
    }
  },
  "share": "disabled",
  "autoupdate": false,
  "lsp": true,
  "formatter": true,
  "default_agent": "build",
  "permission": {
    "*": "allow",
    "doom_loop": "ask"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa",
      "headers": {
        "x-api-key": "{env:EXAAI_API_KEY}"
      },
      "enabled": true
    },
    "parallel-search": {
      "type": "remote",
      "url": "https://search.parallel.ai/mcp",
      "headers": {
        "Authorization": "Bearer {env:PARALLELAI_API_KEY}"
      },
      "enabled": true
    },
    "readability": {
      "type": "local",
      "command": ["npx", "-y", "@mizchi/readability", "--mcp"],
      "enabled": true
    }
  },
  "agent": {
    "plan": {
      "disable": true
    },
    "idea": {
      "description": "Primary ideation agent for early-stage exploration and problem framing before planning; hand off to `spec` by switching agents with the same chat history.",
      "mode": "primary",
      "model": "github-copilot/gpt-5.4-mini",
      "permission": {
        "edit": {
          "*": "deny"
        },
        "question": "allow",
        "write": {
          "*": "deny"
        }
      },
      "prompt": "{file:./prompts/idea.md}"
    },
    "spec": {
      "description": "Primary planning agent that handles both ambiguous and well-scoped requests through iterative specification elicitation and systematic planning workflow.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": {
          "*": "deny",
          ".agents/plans/*.md": "allow"
        },
        "external_directory": {
          ".agents/plans": "allow",
          ".agents/plans/draft": "allow"
        },
        "question": "allow",
        "read": {
          ".agents/plans/draft/*.md": "allow"
        },
        "write": {
          "*": "deny",
          ".agents/plans/*.md": "allow"
        }
      },
      "prompt": "{file:./prompts/spec.md}",
      "reasoningEffort": "high"
    },
    "build": {
      "description": "Primary build/validation agent with proactive best-effort delegation to testing and debugging subagents.",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": {
          "*": "allow"
        },
        "write": {
          "*": "allow"
        }
      },
      "prompt": "{file:./prompts/build.md}",
      "reasoningEffort": "medium"
    },
    "operator": {
      "description": "Primary ops agent for system operations, troubleshooting, server provisioning, and environment setup with explicit confirmation for dangerous actions.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "permission": {
        "*": "allow",
        "doom_loop": "ask",
        "webfetch": "deny",
        "websearch": "deny"
      },
      "prompt": "{file:./prompts/operator.md}"
    },
    "sensei": {
      "description": "Primary explanation agent that teaches reports and git revisions/ranges to project outsiders after calibrating user understanding.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "permission": {
        "bash": {
          "*": "deny",
          "git *&&*": "deny",
          "git *--output*": "deny",
          "git *;*": "deny",
          "git *>*": "deny",
          "git *|*": "deny",
          "git diff*": "ask",
          "git log*": "ask",
          "git merge-base*": "ask",
          "git rev-list*": "ask",
          "git rev-parse*": "ask",
          "git show*": "ask",
          "git status*": "ask"
        },
        "edit": {
          "*": "deny"
        },
        "question": "allow",
        "write": {
          "*": "deny"
        }
      },
      "prompt": "{file:./prompts/sensei.md}",
      "reasoningEffort": "medium"
    },
    "reviewer": {
      "description": "Primary orchestrated reviewer for code written by others, with exploration, optional research, multi-perspective subreviews, and report output.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "permission": {
        "bash": "allow",
        "edit": {
          "*": "deny",
          ".agents/reports/*.md": "allow"
        },
        "external_directory": {
          ".agents/reports": "allow"
        },
        "question": "allow",
        "write": {
          "*": "deny",
          ".agents/reports/*.md": "allow"
        }
      },
      "prompt": "{file:./prompts/reviewer.md}",
      "reasoningEffort": "high"
    },
    "debugger": {
      "description": "Performs command-driven bug investigation with reproduction, root-cause analysis, and evidence-only reporting.",
      "mode": "all",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": {
          "*": "deny",
          ".agents/reports/*.md": "allow",
          "/private/tmp/**": "allow",
          "/tmp/**": "allow"
        },
        "external_directory": {
          ".agents/reports": "allow",
          "/nix/store/*": "allow",
          "/private/tmp/*": "allow",
          "/tmp/*": "allow"
        },
        "read": {
          ".agents/reports/*.md": "allow",
          "/nix/store": "allow",
          "/nix/store/*": "allow",
          "/private/tmp/*": "allow",
          "/tmp/*": "allow"
        },
        "write": {
          "*": "deny",
          ".agents/reports/*.md": "allow",
          "/private/tmp/**": "allow",
          "/tmp/**": "allow"
        }
      },
      "prompt": "{file:./prompts/debugger.md}",
      "reasoningEffort": "medium"
    },
    "draft_planner": {
      "description": "Creates direction-setting draft plan files for user approval before detailed final planning.",
      "mode": "subagent",
      "model": "github-copilot/gpt-5.4-mini",
      "permission": {
        "edit": {
          "*": "deny",
          ".agents/plans/draft/*.md": "allow"
        },
        "external_directory": {
          ".agents/plans/draft": "allow"
        },
        "write": {
          "*": "deny",
          ".agents/plans/draft/*.md": "allow"
        }
      },
      "prompt": "{file:./prompts/draft_planner.md}",
      "reasoningEffort": "high"
    },
    "explore": {
      "description": "Read-only exploration agent that uses relevant skills provided by primary-agent delegation context.",
      "model": "github-copilot/gpt-5.4-mini",
      "permission": {
        "edit": {
          "*": "deny"
        },
        "write": {
          "*": "deny"
        }
      },
      "prompt": "{file:./prompts/explore.md}",
      "reasoningEffort": "high"
    },
    "plan_reviewer": {
      "description": "Performs strict read-only review of final plan and test-spec files (`*.md`) with actionable revisions.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": {
          "*": "deny"
        },
        "write": {
          "*": "deny"
        }
      },
      "prompt": "{file:./prompts/plan_reviewer.md}",
      "reasoningEffort": "low"
    },
    "code_reviewer": {
      "description": "Performs strict read-only code review with severity-ordered findings and concrete file/line evidence.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": {
          "*": "deny"
        },
        "write": {
          "*": "deny"
        }
      },
      "prompt": "{file:./prompts/code_reviewer.md}",
      "reasoningEffort": "medium"
    },
    "internet_research": {
      "description": "Performs targeted internet research when primary planning agents have material knowledge uncertainty.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": {
          "*": "deny",
          ".agents/research/*.md": "allow"
        },
        "external_directory": {
          ".agents/research": "allow"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "write": {
          "*": "deny",
          ".agents/research/*.md": "allow"
        }
      },
      "prompt": "{file:./prompts/internet_research.md}",
      "reasoningEffort": "medium"
    },
    "tester": {
      "description": "Read-only test runner that triages failures and writes failure-report files when suites fail.",
      "mode": "subagent",
      "model": "github-copilot/gpt-5.4-mini",
      "permission": {
        "edit": {
          "*": "ask",
          ".agents/reports/*.md": "allow",
          "/private/tmp/**": "allow",
          "/tmp/**": "allow"
        },
        "external_directory": {
          ".agents/reports": "allow",
          "/nix/store/*": "allow",
          "/private/tmp/*": "allow",
          "/tmp/*": "allow"
        },
        "read": {
          ".agents/reports/*.md": "allow",
          "/nix/store": "allow",
          "/nix/store/*": "allow",
          "/private/tmp/*": "allow",
          "/tmp/*": "allow"
        },
        "write": {
          "*": "ask",
          ".agents/reports/*.md": "allow",
          "/private/tmp/**": "allow",
          "/tmp/**": "allow"
        }
      },
      "prompt": "{file:./prompts/tester.md}",
      "reasoningEffort": "high"
    }
  },
  "experimental": {
    "mcp_timeout": 1200000
  },
  "plugin": ["./plugin/osc99-notify.ts"]
}
