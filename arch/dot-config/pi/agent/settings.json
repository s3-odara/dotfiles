{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.4-mini",
  "defaultThinkingLevel": "high",
  "theme": "system",
  "enabledModels": [
    "openai-codex/*",
    "opencode-go/*"
  ],
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3
  },
  "warnings": {
    "missingMcpServers": true,
    "missingLanguageServers": true,
    "unsupportedThinking": true
  },
  "lastChangelogVersion": "0.80.3",
  "packages": [
    "npm:pi-mcp-adapter",
    "npm:@spences10/pi-lsp"
  ]
}