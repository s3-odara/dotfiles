{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "medium",
  "theme": "system",
  "externalEditor": "vim",
  "enableAnalytics": false,
  "enableInstallTelemetry": false,
  "enabledModels": [
    "openai-codex/*",
    "opencode-go/*"
  ],
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3
  },
  "steeringMode": "all",
  "warnings": {
    "missingMcpServers": true,
    "missingLanguageServers": true,
    "unsupportedThinking": true
  },
  "terminal": {
    "showImages": true
  },
  "images": {
    "autoResize": true
  },
  "lastChangelogVersion": "0.80.3",
  "packages": [
    "npm:pi-mcp-adapter",
    "npm:@spences10/pi-lsp"
  ],
  "showHardwareCursor": false
}