# ~/.zshrc
# Interactive shell configuration.

[[ -o interactive ]] || return

# Helpers
_prepend_fpath_if_dir() {
  local dir="$1"
  [[ -d "$dir" ]] || return 0
  fpath=("$dir" $fpath)
}

_source_first_readable() {
  local file
  for file in "$@"; do
    [[ -r "$file" ]] || continue
    source "$file"
    return 0
  done
  return 1
}

# Completion
_prepend_fpath_if_dir /usr/share/zsh/site-functions
_prepend_fpath_if_dir /usr/share/zsh/plugins

autoload -Uz compinit
_compdump="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump"
mkdir -p -- "${_compdump:h}" 2>/dev/null
compinit -d "${_compdump}"

setopt COMPLETE_IN_WORD
setopt AUTO_LIST
setopt AUTO_MENU
setopt AUTO_PARAM_SLASH

zstyle ':completion:*' menu select
zstyle ':completion:*' completer _complete _approximate
zstyle ':completion:*' group-name ''
zstyle ':completion:*' insert-tab false
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*' list-dirs-first true
zstyle ':completion:*' show-ambiguity true
zstyle ':completion:*' squeeze-slashes true
zstyle ':completion:*' use-cache true
zstyle ':completion:*' matcher-list \
    'r:|[._-/]=* r:|=*' \
    'l:|=* r:|=*'

zstyle ':completion:*:approximate:*' max-errors 1 numeric

# Shell behavior
KEYTIMEOUT=5
setopt interactivecomments
setopt PROMPT_SUBST

# History (XDG)
HISTFILE="${XDG_STATE_HOME:-$HOME/.local/state}/zsh/history"
mkdir -p -- "${HISTFILE:h}" 2>/dev/null
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_REDUCE_BLANKS
setopt HIST_VERIFY

# CD
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt NO_PUSHD_SILENT
setopt PUSHD_MINUS
export cdpath=(~ ~/git)

# Job Control
setopt AUTO_CONTINUE
setopt CHECK_JOBS
setopt CHECK_RUNNING_JOBS
setopt HUP

# I/O
setopt NO_CLOBBER
setopt NO_CLOBBER_EMPTY
setopt NO_RM_STAR_SILENT
setopt NO_RM_STAR_WAIT

# Hooks
autoload -Uz add-zsh-hook

# Key bindings
autoload -Uz up-line-or-beginning-search down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search

bindkey '^H' history-incremental-pattern-search-backward
[[ -n "${terminfo[kcuu1]:-}" ]] && bindkey "${terminfo[kcuu1]}" up-line-or-beginning-search
[[ -n "${terminfo[kcud1]:-}" ]] && bindkey "${terminfo[kcud1]}" down-line-or-beginning-search
# Alias
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -I'

# Keep GPG_TTY fresh and inform gpg-agent.
_gpg_update_tty() {
  export GPG_TTY="${TTY:-$(tty 2>/dev/null)}"
  command -v gpg-connect-agent >/dev/null 2>&1 || return 0
  gpg-connect-agent updatestartuptty /bye >/dev/null 2>&1 || true
}
add-zsh-hook precmd _gpg_update_tty

# Prompt
autoload -Uz vcs_info

zstyle ':vcs_info:*' enable git
zstyle ':vcs_info:git:*' check-for-changes true

zstyle ':vcs_info:git:*' formats       ' on %F{yellow}%b%f%c%u%m'
zstyle ':vcs_info:git:*' actionformats ' on %F{yellow}%b%f (%F{magenta}%a%f)%c%u%m'

zstyle ':vcs_info:git:*' stagedstr     ' %F{green}●%f'
zstyle ':vcs_info:git:*' unstagedstr   ' %F{red}●%f'

zstyle ':vcs_info:git*+set-message:*' hooks git-untracked
+vi-git-untracked() {
  [[ "$1" == "1" ]] || return 0

  local untracked
  untracked=$(command git ls-files --others --exclude-standard 2>/dev/null | command head -n 1)

  if [[ -n "$untracked" ]]; then
    hook_com[misc]=' %F{magenta}●%f'   # ← untracked 
  else
    hook_com[misc]=''
  fi
}

add-zsh-hook precmd vcs_info

# Command duration on RPROMPT (>= 3s)
zmodload -F zsh/datetime b:EPOCHREALTIME 2>/dev/null || true

typeset -gF __cmd_start=0.0

_cmdtimer_preexec() {
  if (( ${+EPOCHREALTIME} )); then
    __cmd_start=$EPOCHREALTIME
  else
    __cmd_start=$SECONDS
  fi
}

_cmdtimer_precmd() {
  local -F elapsed=0.0
  local out
  local -i total h m s

  # default: show nothing
  RPROMPT=''

  (( __cmd_start > 0 )) || return

  if (( ${+EPOCHREALTIME} )); then
    elapsed=$(( EPOCHREALTIME - __cmd_start ))
  else
    elapsed=$(( SECONDS - __cmd_start ))
  fi
  __cmd_start=0.0

  (( elapsed >= 3.0 )) || return

  total=$(( elapsed + 0.5 ))   # 四捨五入（切り捨てなら total=$(( elapsed ))

  h=$(( total / 3600 ))
  m=$(( (total % 3600) / 60 ))
  s=$(( total % 60 ))

  if (( h > 0 )); then
    printf -v out '%dh%02dm%02ds' $h $m $s
  elif (( m > 0 )); then
    printf -v out '%dm%02ds' $m $s
  else
    printf -v out '%.1fs' $elapsed
  fi

  RPROMPT="%F{cyan}${out}%f"
}

add-zsh-hook preexec _cmdtimer_preexec
add-zsh-hook precmd  _cmdtimer_precmd

setopt transient_rprompt

PROMPT='%F{green}%n%f@%F{blue}%m%f:%~${vcs_info_msg_0_}
%# '

# alias
alias ls='ls --color=auto'

# Plugins
typeset -ga ZSH_AUTOSUGGEST_STRATEGY=(history completion)
ZSH_AUTOSUGGEST_HISTORY_IGNORE='?(#c100,)'

_source_first_readable \
  /usr/share/zsh/site-functions/zsh-autosuggestions.zsh \
  /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh \
  >/dev/null 2>&1

# override syntax highlight color
typeset -gA ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[comment]='fg=#6c7ea6'

# zsh-syntax-highlighting should stay last.
_source_first_readable \
  /usr/share/zsh/site-functions/zsh-syntax-highlighting.zsh \
  /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh \
  >/dev/null 2>&1

# tmux
if [[ -z "$TMUX" && -n "$PS1" ]]; then
  if [[ -n "$TMUX_FORCE_NEW" ]]; then
    tmux new-session
  else
    tmux attach || tmux new
  fi
fi
