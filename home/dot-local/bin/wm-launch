#!/bin/sh
set -eu

runtime_dir="${XDG_RUNTIME_DIR:?wm-launch: XDG_RUNTIME_DIR is not set}"
state_dir="$runtime_dir/wm-launch"
current_file="$state_dir/current"
pid_file="$state_dir/pid"
default_wm="${WAYLAND_WM:-machi}"
crash_count=0
first_run=1

mkdir -p "$state_dir"
trap 'rm -f "$pid_file"' EXIT INT TERM

if [ $# -gt 0 ]; then
    printf '%s\n' "$1" >"$current_file"
elif [ ! -f "$current_file" ]; then
    printf '%s\n' "$default_wm" >"$current_file"
fi

while :; do
    wm=
    if [ -f "$current_file" ]; then
        wm="$(sed -n '1p' "$current_file" 2>/dev/null || true)"
    fi
    [ -n "$wm" ] || wm="$default_wm"

    if ! command -v "$wm" >/dev/null 2>&1; then
        printf 'wm-launch: %s not found in PATH\n' "$wm" >&2
        rm -f "$pid_file"
        exit 1
    fi

    "$wm" </dev/null &
    child_pid=$!
    printf '%s\n' "$child_pid" >"$pid_file"

    # update-activation-envは既存のportalの状態を変えられない
    # 初回以外は殺して新しい環境変数でD-Bus Activateさせる
    if [ "$first_run" -eq 0 ] && command -v dbus-update-activation-environment >/dev/null 2>&1; then
        new_wd=
        i=0
        while [ "$i" -lt 10 ]; do
            new_wd="$(ls "${XDG_RUNTIME_DIR}"/wayland-* 2>/dev/null | head -n 1)"
            [ -n "$new_wd" ] && break
            sleep 0.1
            i=$((i + 1))
        done
        if [ -n "$new_wd" ]; then
            export WAYLAND_DISPLAY="${new_wd##*/}"
            dbus-update-activation-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE 2>/dev/null || true
            # 15文字以上だとpkill -xで殺せない
            pkill -TERM -f '(^|/)xdg-desktop-portal-wlr([[:space:]]|$)' 2>/dev/null || true
            pkill -TERM -f '(^|/)xdg-desktop-portal([[:space:]]|$)' 2>/dev/null || true
        fi
    fi
    first_run=0

    status=0
    wait "$child_pid" || status=$?
    rm -f "$pid_file"

    next_wm=
    if [ -f "$current_file" ]; then
        next_wm="$(sed -n '1p' "$current_file" 2>/dev/null || true)"
    fi
    [ -n "$next_wm" ] || next_wm="$default_wm"

    if [ "$next_wm" != "$wm" ]; then
        crash_count=0
        continue
    fi

    if [ "$status" -eq 0 ]; then
        exit 0
    fi

    crash_count=$((crash_count + 1))
    if [ "$crash_count" -ge 3 ]; then
        printf 'wm-launch: %s crashed %s times; giving up\n' "$wm" "$crash_count" >&2
        exit "$status"
    fi

    printf 'wm-launch: %s crashed with status %s; restarting (%s/3)\n' \
        "$wm" "$status" "$crash_count" >&2
done
