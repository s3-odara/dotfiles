#!/bin/sh
set -eu

command -v brightnessctl >/dev/null 2>&1 || {
  echo "brightness: brightnessctl not found" >&2
  exit 127
}

: "${XDG_STATE_HOME:=$HOME/.local/state}"
STATE_DIR="$XDG_STATE_HOME/idle-suspend"
BR_FILE="$STATE_DIR/brightness.saved"

umask 077
mkdir -p "$STATE_DIR"

save() {
  val="$(brightnessctl -r get)"
  case "$val" in ''|*[!0-9]*) echo "brightness: unexpected value: $val" >&2; exit 1;; esac

  tmp="$(mktemp "$BR_FILE.tmp.XXXXXXXX")"
  trap 'rm -f "$tmp"' EXIT HUP INT TERM
  printf '%s\n' "$val" >"$tmp"
  mv -f "$tmp" "$BR_FILE"
  trap - EXIT HUP INT TERM
}

do_set() {
  [ $# -eq 1 ] || { echo "brightness: set needs 1 arg (e.g. 10% / 0%)" >&2; exit 2; }
  brightnessctl set "$1" >/dev/null
}

do_restore() {
  keep=0
  if [ "${1-}" = "--keep" ]; then
    keep=1
    shift
  fi

  [ -r "$BR_FILE" ] || exit 0
  IFS= read -r val <"$BR_FILE" || exit 0

  case "$val" in ''|*[!0-9]*) exit 0;; esac

  if brightnessctl -r set "$val" >/dev/null 2>&1; then
    [ "$keep" -eq 1 ] || rm -f "$BR_FILE"
  fi
}

usage() {
  cat >&2 <<'EOF'
usage:
  brightness save
  brightness set <value>          # e.g. 10% / 0%
  brightness save-set <value>
  brightness restore [--keep]
  brightness clear
  brightness get
EOF
}

cmd="${1-}"
[ -n "$cmd" ] || { usage; exit 2; }
shift || true

case "$cmd" in
  save)
    save
    ;;
  set)
    do_set "$@"
    ;;
  save-set|save_and_set|save-and-set)
    save
    do_set "$@"
    ;;
  restore)
    do_restore "$@"
    ;;
  clear)
    rm -f "$BR_FILE"
    ;;
  get)
    brightnessctl get
    ;;
  *)
    usage
    exit 2
    ;;
esac

