#!/bin/sh
set -eu

runtime_dir="${XDG_RUNTIME_DIR:?wm-switch: XDG_RUNTIME_DIR is not set}"
state_dir="$runtime_dir/wm-launch"
current_file="$state_dir/current"
pid_file="$state_dir/pid"

wm="${1:-}"

if [ -z "$wm" ]; then
    current_wm=
    if [ -f "$current_file" ]; then
        current_wm="$(sed -n '1p' "$current_file" 2>/dev/null || true)"
    fi

    if [ -f "$pid_file" ]; then
        current_pid="$(sed -n '1p' "$pid_file" 2>/dev/null || true)"
        if [ -n "$current_pid" ] && kill -0 "$current_pid" 2>/dev/null; then
            if [ -n "$current_wm" ]; then
                printf '%s\n' "$current_wm"
                exit 0
            fi
        fi
    fi

    if [ -n "$current_wm" ]; then
        printf '%s\n' "$current_wm"
        exit 0
    fi

    printf '%s\n' 'usage: wm-switch <wm>' >&2
    exit 64
fi

if ! command -v "$wm" >/dev/null 2>&1; then
    printf 'wm-switch: %s not found in PATH\n' "$wm" >&2
    exit 1
fi

mkdir -p "$state_dir"

current_wm=
if [ -f "$current_file" ]; then
    current_wm="$(sed -n '1p' "$current_file" 2>/dev/null || true)"
fi

old_pid=
if [ -f "$pid_file" ]; then
    old_pid="$(sed -n '1p' "$pid_file" 2>/dev/null || true)"
fi

if [ "$wm" = "$current_wm" ] &&
    [ -n "$old_pid" ] &&
    kill -0 "$old_pid" 2>/dev/null; then
    exit 0
fi

printf '%s\n' "$wm" >"$current_file"

if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
    kill -TERM "$old_pid" 2>/dev/null || true

    i=0
    while kill -0 "$old_pid" 2>/dev/null && [ $i -lt 20 ]; do
        sleep 0.05
        i=$((i + 1))
    done

    if kill -0 "$old_pid" 2>/dev/null; then
        printf 'wm-switch: old WM did not exit in time: %s\n' "$old_pid" >&2
    fi
fi
