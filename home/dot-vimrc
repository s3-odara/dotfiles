nnoremap <silent> <leader>kb <cmd>FuzzyBuffers<CR>
nnoremap <silent> <leader>kg <cmd>FuzzyGrep<CR>
nnoremap <silent> <leader>kh <cmd>FuzzyHelp<CR>
nnoremap <silent> <leader>ki <cmd>FuzzyInBuffer<CR>


" --- ColorScheme (Habamax) ---
function! DefineMyHighlights()
    if g:colors_name is "orbit"
        highlight Normal ctermbg=NONE guibg=NONE
        highlight NonText ctermbg=NONE guibg=NONE
        highlight SpecialKey ctermbg=NONE guibg=NONE
        highlight EndOfBuffer ctermbg=NONE guibg=NONE
    endif
endfunction

augroup TransparentBG
    autocmd!
    autocmd ColorScheme * call DefineMyHighlights()
augroup END

colorscheme orbit

" 特定ファイルタイプ
augroup noindent
  autocmd!
  autocmd FileType html,css setlocal tabstop=2
augroup END

