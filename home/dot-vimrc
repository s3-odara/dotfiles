vim9script
scriptencoding utf-8

const MINPAC_DIR = expand('~/.vim/pack/minpac/opt/minpac')
const XDG_STATE_DIR = empty($XDG_STATE_HOME) ? expand('~/.local/state') : $XDG_STATE_HOME
const SWAP_DIR = XDG_STATE_DIR .. '/vim/swap'
const UNDO_DIR = XDG_STATE_DIR .. '/vim/undo'

def EnsureMinpacInstalled()
  if isdirectory(MINPAC_DIR)
    return
  endif

  system(['git', 'clone', 'https://github.com/k-takata/minpac', MINPAC_DIR])
  packadd minpac
enddef

def g:PackInit()
  packadd minpac
  minpac#init()

  minpac#add('https://github.com/k-takata/minpac.git', {type: 'opt'})

  # UI / Tools
  minpac#add('https://github.com/vim-fuzzbox/fuzzbox.vim.git')
  minpac#add('https://github.com/mattn/emmet-vim.git')
  minpac#add('https://github.com/mao-yining/undotree.vim')
  minpac#add('https://github.com/girishji/easyjump.vim.git')

  # LSP / Completion
  minpac#add('https://github.com/yegappan/lsp.git')

  # Snippet
  minpac#add('https://github.com/hrsh7th/vim-vsnip.git')
  minpac#add('https://github.com/hrsh7th/vim-vsnip-integ.git')
enddef

def EnsureCacheDirs()
  if !isdirectory(SWAP_DIR)
    mkdir(SWAP_DIR, 'p', 0o700)
  endif
  if !isdirectory(UNDO_DIR)
    mkdir(UNDO_DIR, 'p', 0o700)
  endif
enddef

EnsureMinpacInstalled()

command! -bar PackUpdate call g:PackInit() | call minpac#update()
command! -bar PackClean  call g:PackInit() | call minpac#clean()
command! -bar PackStatus packadd minpac | call minpac#status()
&directory = SWAP_DIR .. '//'
&undodir = UNDO_DIR .. '//'

EnsureCacheDirs()

source ~/.vim/config/core.vim
source ~/.vim/config/lib/ime.vim
source ~/.vim/config/completion.vim
source ~/.vim/config/clipboard.vim
source ~/.vim/config/autopairs.vim
source ~/.vim/config/lib/statusline.vim
source ~/.vim/config/statusline.vim
source ~/.vim/config/plugins.vim
source ~/.vim/config/plugins/gitsign.vim
source ~/.vim/config/lsp/settings.vim
source ~/.vim/config/lsp/servers.vim
source ~/.vim/config/lsp.vim
source ~/.vim/config/lib/lsp_helpers.vim
source ~/.vim/config/keymaps.vim
source ~/.vim/config/autocmds.vim
source ~/.vim/config/ui.vim

colorscheme odara
g:ApplyTransparentBackground()
