vim9script
scriptencoding utf-8

const XDG_STATE_DIR = empty($XDG_STATE_HOME) ? expand('~/.local/state') : $XDG_STATE_HOME
const SWAP_DIR = XDG_STATE_DIR .. '/vim/swap'
const UNDO_DIR = XDG_STATE_DIR .. '/vim/undo'

def EnsureCacheDirs()
  if !isdirectory(SWAP_DIR)
    mkdir(SWAP_DIR, 'p', 0o700)
  endif
  if !isdirectory(UNDO_DIR)
    mkdir(UNDO_DIR, 'p', 0o700)
  endif
enddef

&directory = SWAP_DIR .. '//'
&undodir = UNDO_DIR .. '//'

EnsureCacheDirs()

source ~/.vim/config/packages.vim
source ~/.vim/config/core.vim
source ~/.vim/config/lib/ime.vim
source ~/.vim/config/completion.vim
source ~/.vim/config/clipboard.vim
source ~/.vim/config/autopairs.vim
source ~/.vim/config/lib/statusline.vim
source ~/.vim/config/statusline.vim
source ~/.vim/config/plugins.vim
source ~/.vim/config/plugins/gitsign.vim
source ~/.vim/config/lsp/settings.vim
source ~/.vim/config/lsp/servers.vim
source ~/.vim/config/lsp.vim
source ~/.vim/config/lib/lsp_helpers.vim
source ~/.vim/config/keymaps.vim
source ~/.vim/config/autocmds.vim
source ~/.vim/config/ui.vim

colorscheme odara
g:ApplyTransparentBackground()
