" プラグインロード
" Insert Mode
augroup LazyLoadInsert
    autocmd!
    autocmd InsertEnter * ++once packadd vim-lexiv | silent! iunmap <BS>
augroup END

" プラグイン設定

inoremap <expr> <Tab>
      \ pumvisible() ? "\<C-n>" :
      \ vsnip#available(1) ? "\<Plug>(vsnip-expand-or-jump)" :
      \ "\<Tab>"
inoremap <expr> <S-Tab>
      \ pumvisible() ? "\<C-p>" :
      \ vsnip#jumpable(-1) ? "\<Plug>(vsnip-jump-prev)" :
      \ "\<S-Tab>"

" lightline.vim
let g:lightline = {
      \ 'active': {
      \   'left': [ ['mode', 'paste'], ['gitbranch', 'readonly', 'absolutepath', 'modified'] ]
      \ },
      \ 'component_function':{ 'gitbranch': 'Gitbranch' },
      \ }

function! Gitbranch()
    let head = gitbranch#name()
    if head != ""
        let head = "\uf126 " .. head
    endif
    return head
endfunction

inoremap <expr> <PageDown> ScrollCompleteInfo("\<C-e>", "\<PageDown>")
inoremap <expr> <PageUp> ScrollCompleteInfo("\<C-y>", "\<PageUp>")

