@@ -0,0 +1,153 @@
+#include "grammar_checker.hpp"
+#include "mozuku/core/config.hpp"
+#include "text_processor.hpp"
+#include "utf16.hpp"
+
+#include <cstdlib>
+#include <iostream>
+#include <stdexcept>
+#include <string>
+#include <vector>
+
+namespace {
+
+size_t findNthOccurrence(const std::string &text, const std::string &needle,
+                         int occurrence) {
+  size_t pos = 0;
+  for (int i = 0; i <= occurrence; ++i) {
+    pos = text.find(needle, pos);
+    if (pos == std::string::npos) {
+      throw std::runtime_error("token surface not found: " + needle);
+    }
+    if (i != occurrence) {
+      pos += needle.size();
+    }
+  }
+  return pos;
+}
+
+TokenData makeToken(const std::string &text, const std::string &surface,
+                    const std::string &feature, int occurrence) {
+  size_t byteOffset = findNthOccurrence(text, surface, occurrence);
+  int startChar = static_cast<int>(utf8ToUtf16Length(text.substr(0, byteOffset)));
+  int endChar =
+      startChar + static_cast<int>(utf8ToUtf16Length(surface));
+
+  TokenData token;
+  token.line = 0;
+  token.startChar = startChar;
+  token.endChar = endChar;
+  token.surface = surface;
+  token.feature = feature;
+  return token;
+}
+
+MoZukuConfig makeTestConfig() {
+  MoZukuConfig config;
+  config.analysis.grammarCheck = true;
+  config.analysis.rules.commaLimit = false;
+  config.analysis.rules.adversativeGa = false;
+  config.analysis.rules.duplicateParticleSurface = true;
+  config.analysis.rules.adjacentParticles = false;
+  config.analysis.rules.conjunctionRepeat = false;
+  config.analysis.rules.raDropping = false;
+  config.analysis.rules.duplicateParticleSurfaceMaxRepeat = 1;
+  return config;
+}
+
+void expectDiagnosticCount(const std::string &name, const std::string &text,
+                           const std::vector<TokenData> &tokens,
+                           size_t expectedCount) {
+  std::vector<SentenceBoundary> sentences =
+      MoZuku::text::TextProcessor::splitIntoSentences(text);
+  std::vector<Diagnostic> diags;
+  MoZukuConfig config = makeTestConfig();
+
+  MoZuku::grammar::GrammarChecker::checkGrammar(text, tokens, sentences, diags,
+                                                &config);
+
+  if (diags.size() != expectedCount) {
+    std::cerr << name << ": expected " << expectedCount << " diagnostics, got "
+              << diags.size() << "\n";
+    for (const auto &diag : diags) {
+      std::cerr << "  - " << diag.message << "\n";
+    }
+    std::exit(1);
+  }
+}
+
+} // namespace
+
+int main() {
+  expectDiagnosticCount(
+      "連体化の例外", "既存のコードの利用",
+      {
+          makeToken("既存のコードの利用", "の", "助詞,連体化,*,*,*,*,の,ノ,ノ", 0),
+          makeToken("既存のコードの利用", "の", "助詞,連体化,*,*,*,*,の,ノ,ノ", 1),
+      },
+      0);
+
+  expectDiagnosticCount(
+      "格助詞を例外", "オブジェクトを返す関数を公開した",
+      {
+          makeToken("オブジェクトを返す関数を公開した", "を",
+                    "助詞,格助詞,一般,*,*,*,を,ヲ,ヲ", 0),
+          makeToken("オブジェクトを返す関数を公開した", "を",
+                    "助詞,格助詞,一般,*,*,*,を,ヲ,ヲ", 1),
+      },
+      0);
+
+  expectDiagnosticCount(
+      "格助詞が除外", "彼が私が好きだ",
+      {
+          makeToken("彼が私が好きだ", "が",
+                    "助詞,格助詞,一般,*,*,*,が,ガ,ガ", 0),
+          makeToken("彼が私が好きだ", "が",
+                    "助詞,格助詞,一般,*,*,*,が,ガ,ガ", 1),
+      },
+      0);
+
+  expectDiagnosticCount(
+      "かどうか例外", "これにするかどうか検討する",
+      {
+          makeToken("これにするかどうか検討する", "に",
+                    "助詞,格助詞,一般,*,*,*,に,ニ,ニ", 0),
+          makeToken("これにするかどうか検討する", "か",
+                    "助詞,副助詞／並立助詞／終助詞,*,*,*,*,か,カ,カ", 0),
+          makeToken("これにするかどうか検討する", "どう",
+                    "副詞,助詞類接続,*,*,*,*,どう,ドウ,ドー", 0),
+          makeToken("これにするかどうか検討する", "か",
+                    "助詞,副助詞／並立助詞／終助詞,*,*,*,*,か,カ,カ", 1),
+      },
+      0);
+
+  expectDiagnosticCount(
+      "句読点で区切れば非検知", "材料不足で、代替素材で製品を作った。",
+      {
+          makeToken("材料不足で、代替素材で製品を作った。", "で",
+                    "助詞,格助詞,一般,*,*,*,で,デ,デ", 0),
+          makeToken("材料不足で、代替素材で製品を作った。", "で",
+                    "助詞,格助詞,一般,*,*,*,で,デ,デ", 1),
+      },
+      0);
+
+  expectDiagnosticCount(
+      "通常の重複助詞", "私は彼は好きだ",
+      {
+          makeToken("私は彼は好きだ", "は", "助詞,係助詞,*,*,*,*,は,ハ,ワ", 0),
+          makeToken("私は彼は好きだ", "は", "助詞,係助詞,*,*,*,*,は,ハ,ワ", 1),
+      },
+      1);
+
+  expectDiagnosticCount(
+      "句読点なしは検知", "材料不足で代替素材で製品を作った。",
+      {
+          makeToken("材料不足で代替素材で製品を作った。", "で",
+                    "助詞,格助詞,一般,*,*,*,で,デ,デ", 0),
+          makeToken("材料不足で代替素材で製品を作った。", "で",
+                    "助詞,格助詞,一般,*,*,*,で,デ,デ", 1),
+      },
+      1);
+
+  return 0;
+}
