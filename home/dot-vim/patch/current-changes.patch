+bool isDuplicateParticleSurfaceIgnored(const TokenData &token) {
+  DetailedPOS pos = parsePos(token.feature);
+  if (!pos.isParticle()) {
+    return false;
+  }
+
+  // textlint-rule-no-doubled-joshi に寄せて既定の例外を許容する。
+  if (pos.subPOS1 == "連体化" && token.surface == "の") {
+    return true;
+  }
+  if (pos.subPOS1 == "格助詞" && token.surface == "を") {
+    return true;
+  }
+  if (pos.subPOS1 == "接続助詞" && token.surface == "て") {
+    return true;
+  }
+  if (pos.subPOS1 == "並立助詞") {
+    return true;
+  }
+
+  // 誤検知が多い格助詞「が」は duplicateParticleSurface では検知しない。
+  if (pos.subPOS1 == "格助詞" && token.surface == "が") {
+    return true;
+  }
+
+  return false;
+}
+
+bool isKadoUkaException(const std::vector<TokenData> &tokens, size_t index,
+                        const TokenData &currentToken,
+                        const TokenData &lastToken) {
+  if (currentToken.surface != "か" || lastToken.surface != "か") {
+    return false;
+  }
+
+  DetailedPOS currentPos = parsePos(currentToken.feature);
+  DetailedPOS lastPos = parsePos(lastToken.feature);
+  if (!currentPos.isParticle() || !lastPos.isParticle()) {
+    return false;
+  }
+
+  if (index == 0) {
+    return false;
+  }
+
+  const auto &prevToken = tokens[index - 1];
+  return prevToken.surface == "どう";
+}
+
+bool containsDelimiterPunctuation(const std::string &text, size_t startByte,
+                                  size_t endByte) {
+  if (startByte >= endByte || startByte >= text.size()) {
+    return false;
+  }
+
+  const size_t safeEnd = std::min(endByte, text.size());
+  const std::string_view between(text.data() + startByte, safeEnd - startByte);
+
+  static const std::string punctuations[] = {"、", "。", "，", ",", "．", ".",
+                                             "？", "?", "！", "!"};
+  for (const auto &punctuation : punctuations) {
+    if (between.find(punctuation) != std::string_view::npos) {
+      return true;
+    }
+  }
+
+  return false;
+}
