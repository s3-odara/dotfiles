diff --git a/mozuku-lsp/tests/analyzer_semantic_highlight_test.cpp b/mozuku-lsp/tests/analyzer_semantic_highlight_test.cpp
new file mode 100644
index 0000000..01fc280
--- /dev/null
+++ b/mozuku-lsp/tests/analyzer_semantic_highlight_test.cpp
@@ -0,0 +1,62 @@
+#include "analyzer.hpp"
+
+#include <cstdlib>
+#include <iostream>
+#include <string>
+#include <vector>
+
+int main() {
+  MoZuku::Analyzer analyzer;
+  MoZukuConfig config;
+  config.analysis.enableCaboCha = true;
+  config.analysis.grammarCheck = false;
+
+  if (!analyzer.initialize(config)) {
+    std::cerr << "failed to initialize analyzer\n";
+    return EXIT_FAILURE;
+  }
+
+  const std::string text = "私が駅に行く。";
+  const auto baseTokens = analyzer.analyzeText(text);
+  const auto semanticTokens =
+      analyzer.buildSemanticHighlightTokens(text, baseTokens);
+  const auto dependencies = analyzer.analyzeDependencies(text);
+
+  bool hasSubject = false;
+  bool hasDestination = false;
+  bool hasPredicate = false;
+
+  for (const auto &token : semanticTokens) {
+    if (token.surface == "私" && token.tokenType == "keyword") {
+      hasSubject = true;
+    }
+    if (token.surface == "駅" && token.tokenType == "type") {
+      hasDestination = true;
+    }
+    if (token.surface == "行く" && token.tokenType == "function") {
+      hasPredicate = true;
+    }
+  }
+
+  if (hasSubject && hasDestination && hasPredicate) {
+    return EXIT_SUCCESS;
+  }
+
+  std::cerr << "semantic tokens:";
+  for (const auto &token : semanticTokens) {
+    std::cerr << " " << token.surface << "=" << token.tokenType;
+  }
+  std::cerr << "\n";
+  std::cerr << "base tokens:";
+  for (const auto &token : baseTokens) {
+    std::cerr << " " << token.surface << "=" << token.tokenType;
+  }
+  std::cerr << "\n";
+  std::cerr << "dependencies:";
+  for (const auto &dep : dependencies) {
+    std::cerr << " [" << dep.chunkId << "->" << dep.headId << ":" << dep.text
+              << "]";
+  }
+  std::cerr << "\n";
+  return EXIT_FAILURE;
+}
