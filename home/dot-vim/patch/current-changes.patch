+      {chunkToken(0, 0, 0, "私", pos("名詞")),
+       chunkToken(0, 1, 1, "が", pos("助詞", "格助詞")),
+       chunkToken(1, 2, 0, "ご飯", pos("名詞")),
+       chunkToken(1, 3, 1, "を", pos("助詞", "格助詞")),
+       chunkToken(2, 4, 0, "食べる", posWithBase("動詞", "自立", "食べる")),
+       chunkToken(2, 5, 1, "。", pos("記号"))},
+      {{"私", "keyword"},
+       {"が", "keyword"},
+       {"ご飯", "type"},
+       {"を", "type"},
+       {"食べる", "function"}});
+
+  ok &= expectRoles(
+      "駅に行く",
