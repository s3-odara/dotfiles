diff --git a/mozuku-lsp/src/semantic_role_highlighter.cpp b/mozuku-lsp/src/semantic_role_highlighter.cpp
new file mode 100644
index 0000000..f3689c9
--- /dev/null
+++ b/mozuku-lsp/src/semantic_role_highlighter.cpp
@@ -0,0 +1,797 @@
+#include "semantic_role_highlighter.hpp"
+
+#include "encoding_utils.hpp"
+#include "pos_analyzer.hpp"
+#include "text_processor.hpp"
+#include "utf16.hpp"
+
+#include <algorithm>
+#include <cabocha.h>
+#include <unordered_map>
+#include <unordered_set>
+#include <utility>
+
+namespace {
+
+using MoZuku::core::ChunkDependencyInfo;
+using MoZuku::core::DetailedPOS;
+using MoZuku::core::TokenData;
+using MoZuku::semantic::ChunkTokenInfo;
+
+enum class SemanticRole {
+  None,
+  Subject,
+  Predicate,
+  Complement,
+};
+
+struct RoleAssignment {
+  SemanticRole role{SemanticRole::None};
+  int priority{0};
+};
+
+struct NormalizedCaseInfo {
+  std::string terminalParticle;
+  bool hasTopic{false};
+};
+
+bool isIndependentVerb(const DetailedPOS &pos) {
+  return pos.mainPOS == "動詞" && pos.subPOS1 != "非自立" && pos.subPOS1 != "接尾";
+}
+
+bool isVerbLike(const DetailedPOS &pos) { return pos.mainPOS == "動詞"; }
+
+bool isIndependentAdjective(const DetailedPOS &pos) {
+  return pos.mainPOS == "形容詞" && pos.subPOS1 != "非自立";
+}
+
+bool isCopulaAuxiliary(const ChunkTokenInfo &token) {
+  return token.pos.mainPOS == "助動詞" &&
+         (token.pos.baseForm == "だ" || token.pos.baseForm == "です");
+}
+
+bool isPredicateContent(const DetailedPOS &pos) {
+  return pos.mainPOS != "助詞" && pos.mainPOS != "助動詞" &&
+         pos.mainPOS != "記号";
+}
+
+bool containsSahenMarker(const std::string &value) {
+  return value.find("サ変") != std::string::npos;
+}
+
+bool isSahenNoun(const ChunkTokenInfo &token) {
+  if (token.pos.mainPOS != "名詞") {
+    return false;
+  }
+  return containsSahenMarker(token.pos.subPOS1) ||
+         containsSahenMarker(token.pos.subPOS2) ||
+         containsSahenMarker(token.pos.subPOS3);
+}
+
+bool isSuruLikeVerb(const ChunkTokenInfo &token) {
+  if (token.pos.mainPOS != "動詞") {
+    return false;
+  }
+  return token.pos.baseForm == "する" || token.pos.baseForm == "為る" ||
+         token.pos.baseForm == "できる" || token.pos.baseForm == "出来る";
+}
+
+bool isPredicateBridgeParticle(const ChunkTokenInfo &token) {
+  return token.pos.mainPOS == "助詞" && token.pos.subPOS1 == "接続助詞" &&
+         (token.surface == "て" || token.surface == "で");
+}
+
+bool isPredicateSuffixCandidate(const ChunkTokenInfo &token) {
+  if (token.pos.mainPOS == "助動詞") {
+    return true;
+  }
+  if (token.pos.mainPOS == "動詞") {
+    return token.pos.subPOS1 == "非自立" || isSuruLikeVerb(token);
+  }
+  if (token.pos.mainPOS == "形容詞") {
+    return token.pos.subPOS1 == "非自立" || token.pos.baseForm == "ない" ||
+           token.pos.baseForm == "無い" || token.pos.baseForm == "ほしい" ||
+           token.pos.baseForm == "欲しい" || token.pos.baseForm == "よい" ||
+           token.pos.baseForm == "良い";
+  }
+  return false;
+}
+
+bool isParallelMarker(const std::vector<std::string> &particles) {
+  return std::find(particles.begin(), particles.end(), "と") != particles.end() ||
+         std::find(particles.begin(), particles.end(), "や") != particles.end();
+}
+
+bool isExcludedCaseParticle(const std::string &particle) {
+  static const std::unordered_set<std::string> kExcluded = {
+      "で", "へ", "から", "より", "と"};
+  return kExcluded.find(particle) != kExcluded.end();
+}
+
+bool isNominalModifierParticle(const std::string &particle) {
+  return particle == "の" || particle == "な";
+}
+
+bool isAdverbLikeToken(const ChunkTokenInfo &token) {
+  return token.pos.mainPOS == "副詞" || token.pos.mainPOS == "感動詞";
+}
+
+bool isAdverbialNounLike(const ChunkTokenInfo &token) {
+  if (token.pos.mainPOS != "名詞") {
+    return false;
+  }
+  return token.pos.subPOS1 == "副詞可能" || token.pos.subPOS2 == "副詞可能" ||
+         token.pos.subPOS3 == "副詞可能";
+}
+
+bool isNonIndependentNounLike(const ChunkTokenInfo &token) {
+  return token.pos.mainPOS == "名詞" && token.pos.subPOS1 == "非自立";
+}
+
+std::vector<std::string>
+collectFunctionParticles(const ChunkDependencyInfo &chunk,
+                         const std::vector<ChunkTokenInfo> &tokens) {
+  std::vector<std::string> particles;
+  const size_t funcPos =
+      chunk.funcPos < chunk.tokenSize ? chunk.funcPos : chunk.tokenSize;
+
+  for (const auto &token : tokens) {
+    if (token.tokenOffsetInChunk < static_cast<int>(funcPos)) {
+      continue;
+    }
+    if (token.pos.mainPOS != "助詞") {
+      continue;
+    }
+    particles.push_back(token.surface);
+  }
+
+  return particles;
+}
+
+SemanticRole classifyRole(const std::vector<std::string> &particles) {
+  if (particles.empty()) {
+    return SemanticRole::None;
+  }
+
+  NormalizedCaseInfo normalized;
+  for (const auto &particle : particles) {
+    if (particle == "は") {
+      normalized.hasTopic = true;
+      continue;
+    }
+    if (particle == "が" || particle == "を" || particle == "に" ||
+        isExcludedCaseParticle(particle)) {
+      normalized.terminalParticle = particle;
+    }
+  }
+
+  if (normalized.terminalParticle == "が") {
+    return SemanticRole::Subject;
+  }
+  if (normalized.terminalParticle == "を") {
+    return SemanticRole::Complement;
+  }
+  if (normalized.terminalParticle == "に") {
+    return normalized.hasTopic ? SemanticRole::Subject
+                               : SemanticRole::Complement;
+  }
+  if (normalized.terminalParticle.empty() && normalized.hasTopic) {
+    return SemanticRole::Subject;
+  }
+  if (!normalized.terminalParticle.empty() &&
+      isExcludedCaseParticle(normalized.terminalParticle)) {
+    return SemanticRole::None;
+  }
+
+  return SemanticRole::None;
+}
+
+std::string tokenTypeForRole(SemanticRole role) {
+  switch (role) {
+  case SemanticRole::Subject:
+    return "keyword";
+  case SemanticRole::Predicate:
+    return "function";
+  case SemanticRole::Complement:
+    return "type";
+  case SemanticRole::None:
+    return "";
+  }
+
+  return "";
+}
+
+int priorityForRole(SemanticRole role) {
+  switch (role) {
+  case SemanticRole::Subject:
+    return 4;
+  case SemanticRole::Complement:
+    return 4;
+  case SemanticRole::Predicate:
+    return 3;
+  case SemanticRole::None:
+    return 0;
+  }
+
+  return 0;
+}
+
+int findPredicateHeadOffset(const std::vector<ChunkTokenInfo> &chunkTokenList,
+                            size_t predicateLimit);
+
+void assignChunkTokens(
+    int chunkId, SemanticRole role,
+    const std::unordered_map<int, std::vector<ChunkTokenInfo>> &tokensByChunk,
+    std::unordered_map<int, RoleAssignment> &assignments) {
+  auto tokensIt = tokensByChunk.find(chunkId);
+  if (tokensIt == tokensByChunk.end()) {
+    return;
+  }
+
+  const auto &chunkTokens = tokensIt->second;
+  for (const auto &token : chunkTokens) {
+    if (token.pos.mainPOS == "記号") {
+      continue;
+    }
+
+    auto &assignment = assignments[token.tokenIndex];
+    const int priority = priorityForRole(role);
+    if (priority >= assignment.priority) {
+      assignment = {role, priority};
+    }
+  }
+}
+
+bool chunkHasPredicateLikeCore(
+    const ChunkDependencyInfo &chunk,
+    const std::vector<ChunkTokenInfo> &chunkTokenList) {
+  return findPredicateHeadOffset(chunkTokenList, chunk.tokenSize) >= 0;
+}
+
+bool chunkHasOnlyAdverbialContent(
+    const std::vector<ChunkTokenInfo> &chunkTokenList) {
+  bool sawContent = false;
+  for (const auto &token : chunkTokenList) {
+    if (token.pos.mainPOS == "助詞" || token.pos.mainPOS == "助動詞" ||
+        token.pos.mainPOS == "記号") {
+      continue;
+    }
+    sawContent = true;
+    if (!isAdverbLikeToken(token)) {
+      return false;
+    }
+  }
+  return sawContent;
+}
+
+const ChunkTokenInfo *
+findArgumentHeadToken(const ChunkDependencyInfo &chunk,
+                      const std::vector<ChunkTokenInfo> &chunkTokenList) {
+  const size_t predicateLimit =
+      chunk.funcPos < chunk.tokenSize ? chunk.funcPos : chunk.tokenSize;
+  for (auto it = chunkTokenList.rbegin(); it != chunkTokenList.rend(); ++it) {
+    if (it->tokenOffsetInChunk >= static_cast<int>(predicateLimit)) {
+      continue;
+    }
+    if (it->pos.mainPOS == "助詞" || it->pos.mainPOS == "助動詞" ||
+        it->pos.mainPOS == "記号") {
+      continue;
+    }
+    return &*it;
+  }
+  return nullptr;
+}
+
+bool shouldTreatAsArgumentHead(const ChunkDependencyInfo &chunk,
+                               const std::vector<ChunkTokenInfo> &chunkTokenList,
+                               SemanticRole role) {
+  if (role == SemanticRole::None) {
+    return false;
+  }
+
+  const ChunkTokenInfo *headToken = findArgumentHeadToken(chunk, chunkTokenList);
+  if (!headToken) {
+    return false;
+  }
+  if (isAdverbLikeToken(*headToken) || isAdverbialNounLike(*headToken)) {
+    return false;
+  }
+  return true;
+}
+
+bool shouldExpandArgumentSpan(const ChunkDependencyInfo &chunk,
+                              const std::vector<ChunkTokenInfo> &chunkTokenList) {
+  const ChunkTokenInfo *headToken = findArgumentHeadToken(chunk, chunkTokenList);
+  if (!headToken) {
+    return false;
+  }
+  return !isNonIndependentNounLike(*headToken);
+}
+
+bool shouldIncludeDirectModifierChunk(
+    const ChunkDependencyInfo &chunk,
+    const std::vector<ChunkTokenInfo> &chunkTokenList) {
+  const auto particles = collectFunctionParticles(chunk, chunkTokenList);
+  if (isParallelMarker(particles)) {
+    return true;
+  }
+  if (particles.empty()) {
+    return !chunkHasOnlyAdverbialContent(chunkTokenList);
+  }
+
+  const bool hasOnlyNominalModifierParticles = std::all_of(
+      particles.begin(), particles.end(),
+      [](const std::string &particle) {
+        return isNominalModifierParticle(particle);
+      });
+  if (hasOnlyNominalModifierParticles) {
+    return true;
+  }
+
+  return chunkHasPredicateLikeCore(chunk, chunkTokenList);
+}
+
+void collectArgumentSpanChunks(
+    int chunkId,
+    const std::unordered_map<int, std::vector<int>> &childrenByHead,
+    const std::unordered_map<int, ChunkDependencyInfo> &chunksById,
+    const std::unordered_map<int, std::vector<ChunkTokenInfo>> &tokensByChunk,
+    std::unordered_set<int> &result, bool includeAllDescendants) {
+  if (!result.insert(chunkId).second) {
+    return;
+  }
+
+  auto childrenIt = childrenByHead.find(chunkId);
+  if (childrenIt == childrenByHead.end()) {
+    return;
+  }
+
+  for (int childId : childrenIt->second) {
+    auto chunkIt = chunksById.find(childId);
+    auto tokensIt = tokensByChunk.find(childId);
+    if (chunkIt == chunksById.end() || tokensIt == tokensByChunk.end()) {
+      continue;
+    }
+
+    const bool shouldInclude =
+        includeAllDescendants ||
+        shouldIncludeDirectModifierChunk(chunkIt->second, tokensIt->second);
+    if (!shouldInclude) {
+      continue;
+    }
+
+    collectArgumentSpanChunks(childId, childrenByHead, chunksById, tokensByChunk,
+                              result, true);
+  }
+}
+
+int findPredicateHeadOffset(const std::vector<ChunkTokenInfo> &chunkTokenList,
+                            size_t predicateLimit) {
+  int predicateTokenOffset = -1;
+
+  for (const auto &token : chunkTokenList) {
+    if (token.tokenOffsetInChunk >= static_cast<int>(predicateLimit)) {
+      break;
+    }
+    if (isIndependentVerb(token.pos)) {
+      predicateTokenOffset = token.tokenOffsetInChunk;
+    }
+  }
+  if (predicateTokenOffset >= 0) {
+    return predicateTokenOffset;
+  }
+
+  for (const auto &token : chunkTokenList) {
+    if (token.tokenOffsetInChunk >= static_cast<int>(predicateLimit)) {
+      break;
+    }
+    if (isIndependentAdjective(token.pos)) {
+      predicateTokenOffset = token.tokenOffsetInChunk;
+    }
+  }
+  if (predicateTokenOffset >= 0) {
+    return predicateTokenOffset;
+  }
+
+  for (const auto &token : chunkTokenList) {
+    if (token.tokenOffsetInChunk >= static_cast<int>(predicateLimit)) {
+      break;
+    }
+    if (isVerbLike(token.pos)) {
+      predicateTokenOffset = token.tokenOffsetInChunk;
+    }
+  }
+  if (predicateTokenOffset >= 0) {
+    return predicateTokenOffset;
+  }
+
+  int copulaOffset = -1;
+  for (const auto &token : chunkTokenList) {
+    if (isCopulaAuxiliary(token)) {
+      copulaOffset = token.tokenOffsetInChunk;
+      break;
+    }
+  }
+  if (copulaOffset < 0) {
+    return -1;
+  }
+
+  for (auto it = chunkTokenList.rbegin(); it != chunkTokenList.rend(); ++it) {
+    if (it->tokenOffsetInChunk >= copulaOffset) {
+      continue;
+    }
+    if (isPredicateContent(it->pos)) {
+      return it->tokenOffsetInChunk;
+    }
+  }
+
+  return -1;
+}
+
+std::pair<int, int>
+findPredicateSpanOffsets(const std::vector<ChunkTokenInfo> &chunkTokenList,
+                         size_t predicateLimit) {
+  const int headOffset =
+      findPredicateHeadOffset(chunkTokenList, predicateLimit);
+  if (headOffset < 0) {
+    return {-1, -1};
+  }
+
+  int headIndex = -1;
+  for (size_t i = 0; i < chunkTokenList.size(); ++i) {
+    if (chunkTokenList[i].tokenOffsetInChunk == headOffset) {
+      headIndex = static_cast<int>(i);
+      break;
+    }
+  }
+  if (headIndex < 0) {
+    return {-1, -1};
+  }
+
+  int startIndex = headIndex;
+  int endIndex = headIndex;
+  const auto &headToken = chunkTokenList[headIndex];
+
+  if (headIndex > 0 && isSuruLikeVerb(headToken) &&
+      isSahenNoun(chunkTokenList[headIndex - 1])) {
+    startIndex = headIndex - 1;
+  }
+
+  while (endIndex + 1 < static_cast<int>(chunkTokenList.size())) {
+    const auto &next = chunkTokenList[endIndex + 1];
+    if (next.pos.mainPOS == "記号") {
+      break;
+    }
+
+    if (isPredicateSuffixCandidate(next)) {
+      ++endIndex;
+      continue;
+    }
+
+    if (isPredicateBridgeParticle(next) &&
+        endIndex + 2 < static_cast<int>(chunkTokenList.size()) &&
+        isPredicateSuffixCandidate(chunkTokenList[endIndex + 2])) {
+      ++endIndex;
+      continue;
+    }
+
+    if (isPredicateBridgeParticle(next)) {
+      ++endIndex;
+      continue;
+    }
+
+    break;
+  }
+
+  return {startIndex, endIndex};
+}
+
+void assignPredicateSpan(
+    const std::vector<ChunkTokenInfo> &chunkTokenList,
+    std::pair<int, int> predicateSpan,
+    std::unordered_map<int, RoleAssignment> &assignments) {
+  if (predicateSpan.first < 0 || predicateSpan.second < predicateSpan.first) {
+    return;
+  }
+
+  const int priority = priorityForRole(SemanticRole::Predicate);
+  for (int i = predicateSpan.first;
+       i <= predicateSpan.second && i < static_cast<int>(chunkTokenList.size());
+       ++i) {
+    const auto &token = chunkTokenList[i];
+    if (token.pos.mainPOS == "記号") {
+      continue;
+    }
+    auto &assignment = assignments[token.tokenIndex];
+    if (priority >= assignment.priority) {
+      assignment = {SemanticRole::Predicate, priority};
+    }
+  }
+}
+
+void propagateParallelChunks(
+    int chunkId, SemanticRole role,
+    const std::unordered_map<int, std::vector<int>> &childrenByHead,
+    const std::unordered_map<int, ChunkDependencyInfo> &chunksById,
+    const std::unordered_map<int, std::vector<ChunkTokenInfo>> &tokensByChunk,
+    std::unordered_map<int, RoleAssignment> &assignments,
+    std::unordered_set<int> &visited) {
+  if (!visited.insert(chunkId).second) {
+    return;
+  }
+
+  auto childrenIt = childrenByHead.find(chunkId);
+  if (childrenIt == childrenByHead.end()) {
+    return;
+  }
+
+  for (int childId : childrenIt->second) {
+    auto chunkIt = chunksById.find(childId);
+    auto tokensIt = tokensByChunk.find(childId);
+    if (chunkIt == chunksById.end() || tokensIt == tokensByChunk.end()) {
+      continue;
+    }
+
+    const auto particles =
+        collectFunctionParticles(chunkIt->second, tokensIt->second);
+    if (!isParallelMarker(particles)) {
+      continue;
+    }
+
+    assignChunkTokens(childId, role, tokensByChunk, assignments);
+    propagateParallelChunks(childId, role, childrenByHead, chunksById,
+                            tokensByChunk, assignments, visited);
+  }
+}
+
+std::vector<ChunkDependencyInfo>
+extractChunks(const cabocha_tree_t *tree, const std::string &systemCharset) {
+  std::vector<ChunkDependencyInfo> chunks;
+  if (!tree) {
+    return chunks;
+  }
+
+  for (size_t i = 0;
+       i < cabocha_tree_chunk_size(const_cast<cabocha_tree_t *>(tree)); ++i) {
+    const cabocha_chunk_t *chunk =
+        cabocha_tree_chunk(const_cast<cabocha_tree_t *>(tree), i);
+    if (!chunk) {
+      continue;
+    }
+
+    ChunkDependencyInfo info;
+    info.chunkId = static_cast<int>(i);
+    info.headId = chunk->link;
+    info.tokenPos = chunk->token_pos;
+    info.tokenSize = chunk->token_size;
+    info.headPos = chunk->head_pos;
+    info.funcPos = chunk->func_pos >= 0 ? static_cast<size_t>(chunk->func_pos)
+                                        : chunk->token_size;
+
+    for (size_t j = info.tokenPos;
+         j < info.tokenPos + info.tokenSize &&
+         j < cabocha_tree_token_size(const_cast<cabocha_tree_t *>(tree));
+         ++j) {
+      const cabocha_token_t *token =
+          cabocha_tree_token(const_cast<cabocha_tree_t *>(tree), j);
+      if (!token || !token->surface) {
+        continue;
+      }
+      info.text += MoZuku::encoding::systemToUtf8(std::string(token->surface),
+                                                  systemCharset);
+    }
+
+    chunks.push_back(info);
+  }
+
+  return chunks;
+}
+
+std::vector<ChunkTokenInfo>
+extractChunkTokens(const cabocha_tree_t *tree, const std::string &systemCharset,
+                   const std::vector<TokenData> &baseTokens,
+                   const std::vector<ChunkDependencyInfo> &chunks) {
+  std::vector<ChunkTokenInfo> chunkTokens;
+  if (!tree) {
+    return chunkTokens;
+  }
+
+  size_t nextBaseIndex = 0;
+  for (const auto &chunk : chunks) {
+    for (size_t j = 0;
+         j < chunk.tokenSize &&
+         chunk.tokenPos + j <
+             cabocha_tree_token_size(const_cast<cabocha_tree_t *>(tree));
+         ++j) {
+      const cabocha_token_t *token = cabocha_tree_token(
+          const_cast<cabocha_tree_t *>(tree), chunk.tokenPos + j);
+      if (!token || !token->surface) {
+        continue;
+      }
+
+      const std::string surface =
+          MoZuku::encoding::systemToUtf8(std::string(token->surface),
+                                         systemCharset);
+      const std::string feature =
+          token->feature
+              ? MoZuku::encoding::systemToUtf8(std::string(token->feature),
+                                              systemCharset)
+              : "";
+
+      while (nextBaseIndex < baseTokens.size() &&
+             baseTokens[nextBaseIndex].surface != surface) {
+        ++nextBaseIndex;
+      }
+      if (nextBaseIndex >= baseTokens.size()) {
+        return {};
+      }
+
+      chunkTokens.push_back(
+          {chunk.chunkId,
+           static_cast<int>(nextBaseIndex),
+           static_cast<int>(j),
+           surface,
+           MoZuku::pos::POSAnalyzer::parseDetailedPOS(feature.c_str(), "UTF-8")});
+      ++nextBaseIndex;
+    }
+  }
+
+  return chunkTokens;
+}
+
+} // namespace
+
+namespace MoZuku::semantic {
+
+std::vector<TokenData>
+applySemanticRoles(const std::vector<TokenData> &baseTokens,
+                   const std::vector<ChunkDependencyInfo> &chunks,
+                   const std::vector<ChunkTokenInfo> &chunkTokens) {
+  std::unordered_map<int, ChunkDependencyInfo> chunksById;
+  std::unordered_map<int, std::vector<ChunkTokenInfo>> tokensByChunk;
+  std::unordered_map<int, std::vector<int>> childrenByHead;
+  for (const auto &chunk : chunks) {
+    chunksById[chunk.chunkId] = chunk;
+    childrenByHead[chunk.headId].push_back(chunk.chunkId);
+  }
+  for (const auto &token : chunkTokens) {
+    tokensByChunk[token.chunkId].push_back(token);
+  }
+  for (auto &[chunkId, groupedTokens] : tokensByChunk) {
+    std::sort(groupedTokens.begin(), groupedTokens.end(),
+              [](const ChunkTokenInfo &lhs, const ChunkTokenInfo &rhs) {
+                return lhs.tokenOffsetInChunk < rhs.tokenOffsetInChunk;
+              });
+  }
+
+  std::unordered_map<int, RoleAssignment> assignments;
+
+  for (const auto &chunk : chunks) {
+    auto tokensIt = tokensByChunk.find(chunk.chunkId);
+    if (tokensIt == tokensByChunk.end()) {
+      continue;
+    }
+
+    const auto &chunkTokenList = tokensIt->second;
+    const auto predicateSpan =
+        findPredicateSpanOffsets(chunkTokenList, chunk.tokenSize);
+    if (predicateSpan.first < 0) {
+      continue;
+    }
+
+    assignPredicateSpan(chunkTokenList, predicateSpan, assignments);
+
+    auto childrenIt = childrenByHead.find(chunk.chunkId);
+    if (childrenIt == childrenByHead.end()) {
+      continue;
+    }
+
+    for (int childId : childrenIt->second) {
+      auto childChunkIt = chunksById.find(childId);
+      auto childTokensIt = tokensByChunk.find(childId);
+      if (childChunkIt == chunksById.end() || childTokensIt == tokensByChunk.end()) {
+        continue;
+      }
+
+      const auto particles =
+          collectFunctionParticles(childChunkIt->second, childTokensIt->second);
+      const SemanticRole role = classifyRole(particles);
+      if (!shouldTreatAsArgumentHead(childChunkIt->second, childTokensIt->second,
+                                     role)) {
+        continue;
+      }
+
+      std::unordered_set<int> spanChunks;
+      if (shouldExpandArgumentSpan(childChunkIt->second, childTokensIt->second)) {
+        collectArgumentSpanChunks(childId, childrenByHead, chunksById,
+                                  tokensByChunk, spanChunks, false);
+      } else {
+        spanChunks.insert(childId);
+      }
+      for (int spanChunkId : spanChunks) {
+        assignChunkTokens(spanChunkId, role, tokensByChunk, assignments);
+      }
+
+      std::unordered_set<int> visited;
+      propagateParallelChunks(childId, role, childrenByHead, chunksById,
+                              tokensByChunk, assignments, visited);
+    }
+  }
+
+  std::vector<TokenData> result;
+  for (const auto &[tokenIndex, assignment] : assignments) {
+    if (tokenIndex < 0 ||
+        tokenIndex >= static_cast<int>(baseTokens.size()) ||
+        assignment.role == SemanticRole::None) {
+      continue;
+    }
+
+    TokenData token = baseTokens[tokenIndex];
+    token.tokenType = tokenTypeForRole(assignment.role);
+    result.push_back(std::move(token));
+  }
+
+  std::sort(result.begin(), result.end(),
+            [](const TokenData &lhs, const TokenData &rhs) {
+              return std::pair(lhs.line, lhs.startChar) <
+                     std::pair(rhs.line, rhs.startChar);
+            });
+  return result;
+}
+
+std::vector<TokenData>
+buildSemanticRoleTokens(const std::string &text,
+                        const std::vector<TokenData> &baseTokens,
+                        cabocha_t *parser, const std::string &systemCharset) {
+  if (!parser || text.empty() || baseTokens.empty()) {
+    return {};
+  }
+
+  std::vector<TokenData> result;
+  const auto sentences = MoZuku::text::TextProcessor::splitIntoSentences(text);
+  const TextOffsetMapper offsetMapper(text);
+
+  for (const auto &sentence : sentences) {
+    if (sentence.text.empty()) {
+      continue;
+    }
+
+    std::vector<TokenData> sentenceBaseTokens;
+    for (const auto &token : baseTokens) {
+      const size_t startByte = offsetMapper.tokenStartByteOffset(token);
+      if (startByte >= sentence.start && startByte < sentence.end) {
+        sentenceBaseTokens.push_back(token);
+      }
+    }
+    if (sentenceBaseTokens.empty()) {
+      continue;
+    }
+
+    const std::string systemText =
+        MoZuku::encoding::utf8ToSystem(sentence.text, systemCharset);
+    const cabocha_tree_t *tree = cabocha_sparse_totree(parser, systemText.c_str());
+    if (!tree) {
+      continue;
+    }
+
+    const auto chunks = extractChunks(tree, systemCharset);
+    const auto chunkTokens =
+        extractChunkTokens(tree, systemCharset, sentenceBaseTokens, chunks);
+    if (chunks.empty() || chunkTokens.empty()) {
+      continue;
+    }
+
+    auto sentenceResult =
+        applySemanticRoles(sentenceBaseTokens, chunks, chunkTokens);
+    result.insert(result.end(), sentenceResult.begin(), sentenceResult.end());
+  }
+
+  std::sort(result.begin(), result.end(),
+            [](const TokenData &lhs, const TokenData &rhs) {
+              return std::pair(lhs.line, lhs.startChar) <
+                     std::pair(rhs.line, rhs.startChar);
+            });
+  return result;
+}
+
+} // namespace MoZuku::semantic
