+
+DetailedPOS pos(const std::string &mainPOS, const std::string &subPOS1 = "") {
+  DetailedPOS result;
+  result.mainPOS = mainPOS;
+  result.subPOS1 = subPOS1;
+  return result;
+}
+
+DetailedPOS posWithBase(const std::string &mainPOS, const std::string &subPOS1,
+                        const std::string &baseForm) {
+  DetailedPOS result = pos(mainPOS, subPOS1);
+  result.baseForm = baseForm;
+  return result;
+}
+
+DetailedPOS posWithSub2(const std::string &mainPOS, const std::string &subPOS1,
+                        const std::string &subPOS2) {
+  DetailedPOS result = pos(mainPOS, subPOS1);
+  result.subPOS2 = subPOS2;
+  return result;
+}
+
+TokenData token(int startChar, const std::string &surface,
+                const std::string &tokenType) {
+  TokenData result;
+  result.line = 0;
+  result.startChar = startChar;
+  result.endChar = startChar + static_cast<int>(surface.size());
+  result.surface = surface;
+  result.tokenType = tokenType;
+  return result;
+}
+
+ChunkDependencyInfo chunk(int chunkId, int headId, size_t tokenPos,
+                          size_t tokenSize, size_t headPos, size_t funcPos) {
+  ChunkDependencyInfo result;
+  result.chunkId = chunkId;
+  result.headId = headId;
+  result.tokenPos = tokenPos;
+  result.tokenSize = tokenSize;
+  result.headPos = headPos;
+  result.funcPos = funcPos;
+  return result;
+}
+
+ChunkTokenInfo chunkToken(int chunkId, int tokenIndex, int tokenOffsetInChunk,
+                          const std::string &surface, const DetailedPOS &pos) {
+  ChunkTokenInfo result;
+  result.chunkId = chunkId;
+  result.tokenIndex = tokenIndex;
+  result.tokenOffsetInChunk = tokenOffsetInChunk;
+  result.surface = surface;
+  result.pos = pos;
+  return result;
+}
+
+bool expectRoles(const std::string &label, const std::vector<TokenData> &base,
+                 const std::vector<ChunkDependencyInfo> &chunks,
+                 const std::vector<ChunkTokenInfo> &chunkTokens,
+                 const std::vector<std::pair<std::string, std::string>> &expected) {
+  const auto actual = MoZuku::semantic::applySemanticRoles(base, chunks, chunkTokens);
+  std::vector<std::pair<std::string, std::string>> actualBySurface;
+  for (const auto &token : actual) {
+    actualBySurface.emplace_back(token.surface, token.tokenType);
+  }
+
+  if (actualBySurface == expected) {
+    return true;
+  }
+
+  std::cerr << "[FAIL] " << label << "\n";
+  std::cerr << "  expected:";
+  for (const auto &[surface, type] : expected) {
+    std::cerr << " " << surface << "=" << type;
+  }
+  std::cerr << "\n";
+  std::cerr << "  actual:";
+  for (const auto &[surface, type] : actualBySurface) {
+    std::cerr << " " << surface << "=" << type;
+  }
+  std::cerr << "\n";
+  return false;
+}
