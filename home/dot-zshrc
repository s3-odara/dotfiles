# ~/.zshrc
# Interactive shell configuration.

[[ -o interactive ]] || return

# Helpers
_fpath_prepend() {
  local dir="$1"
  [[ -d "$dir" ]] || return 0

  # 既存の同じパスを消してから先頭へ
  fpath=("${(@)fpath:#$dir}")
  fpath=("$dir" "${fpath[@]}")
}

_fpath_append() {
  local dir="$1"
  [[ -d "$dir" ]] || return 0

  # 既存の同じパスを消してから末尾へ
  fpath=("${(@)fpath:#$dir}")
  fpath=("${fpath[@]}" "$dir")
}

_source_first_readable() {
  local file
  for file in "$@"; do
    [[ -r "$file" ]] || continue
    source "$file"
    return 0
  done
  return 1
}

# Completion
_fpath_prepend "${XDG_CONFIG_HOME:-$HOME/.config}/zsh/completions"
_fpath_append /usr/share/zsh/site-functions

autoload -Uz compinit
_compdump="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump"
mkdir -p -- "${_compdump:h}" 2>/dev/null
compinit -d "${_compdump}"

zstyle ':completion:*' menu select
zstyle ':completion:*' completer _complete _approximate
zstyle ':completion:*' group-name ''
zstyle ':completion:*' insert-tab false
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*' list-dirs-first true
zstyle ':completion:*' show-ambiguity true
zstyle ':completion:*' squeeze-slashes false
zstyle ':completion:*' use-cache true
zstyle ':completion:*' matcher-list \
    '' \
    'm:{a-zA-Z}={A-Za-z}' \
    'm:{a-zA-Z}={A-Za-z} r:|[-_./]=* r:|=*'
zstyle ':completion:*:approximate:*' max-errors 3 numeric

# Options

# Completion

setopt ALWAYS_TO_END # 補完確定時に後ろに飛ぶ
setopt COMPLETE_IN_WORD
setopt AUTO_LIST # AUTO_COMPLETEをしてればAUTO_LISTとAUTO_MENUはnoop
setopt AUTO_MENU
setopt NO_MENU_COMPLETE
setopt AUTO_PARAM_SLASH
setopt NO_LIST_BEEP
setopt GLOB_COMPLETE

# Expansion and Globbing
autoload -Uz zargs
setopt EXTENDED_GLOB
setopt NO_GLOB_DOTS
setopt GLOB_STAR_SHORT

# Shell behavior
KEYTIMEOUT=5
setopt interactivecomments
setopt PROMPT_SUBST

# History (XDG)
HISTFILE="${XDG_STATE_HOME:-$HOME/.local/state}/zsh/history"
mkdir -p -- "${HISTFILE:h}" 2>/dev/null
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_REDUCE_BLANKS
setopt HIST_VERIFY

# CD
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt NO_PUSHD_SILENT
setopt PUSHD_MINUS
export cdpath=(~ ~/git)

# Job Control
setopt AUTO_CONTINUE
setopt CHECK_JOBS
setopt CHECK_RUNNING_JOBS
setopt HUP

# I/O
setopt NO_CLOBBER
setopt NO_CLOBBER_EMPTY
setopt NO_RM_STAR_SILENT
setopt NO_RM_STAR_WAIT
setopt IGNORE_EOF

# Shell emulation
setopt APPEND_CREATE # no_clobberの時でも>>で新規作成できる

# Hooks
autoload -Uz add-zsh-hook

# Key bindings
autoload -Uz up-line-or-beginning-search down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
bindkey -v  # vi mode

bindkey '^H' history-incremental-pattern-search-backward
[[ -n "${terminfo[kcuu1]:-}" ]] && bindkey "${terminfo[kcuu1]}" up-line-or-beginning-search
[[ -n "${terminfo[kcud1]:-}" ]] && bindkey "${terminfo[kcud1]}" down-line-or-beginning-search
bindkey '^[[A' up-line-or-beginning-search
bindkey '^[[B' down-line-or-beginning-search
bindkey '^[OA' up-line-or-beginning-search
bindkey '^[OB' down-line-or-beginning-search
bindkey -M isearch '^M' accept-search
bindkey -M isearch '^J' accept-search

# Alias
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -I'
alias ls='ls --color=auto'

# PATH
export PATH="$HOME/.local/bin:$PATH"

# Keep GPG_TTY fresh and inform gpg-agent.
_gpg_update_tty() {
  export GPG_TTY="${TTY:-$(tty 2>/dev/null)}"
  command -v gpg-connect-agent >/dev/null 2>&1 || return 0
  gpg-connect-agent updatestartuptty /bye >/dev/null 2>&1 || true
}
add-zsh-hook precmd _gpg_update_tty

# Local configuration should run before plugins, and before syntax highlighting.
_zshrc_local="${XDG_CONFIG_HOME:-$HOME/.config}/zsh/zshrc.local"
[[ -r "$_zshrc_local" ]] && source "$_zshrc_local"
unset _zshrc_local

# Plugins
_zsh_autosuggest_strategy_snippets() {
  emulate -L zsh

  local snippet_file="${XDG_CONFIG_HOME:-$HOME/.config}/zsh/snippets"
  [[ -r "$snippet_file" ]] || return

  local prefix="$1"
  local line block

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ -z "$line" ]]; then
      if [[ -n "$block" && "$block" == "$prefix"* ]]; then
        typeset -g suggestion="$block"
        return
      fi
      block=''
      continue
    fi

    if [[ -n "$block" ]]; then
      block+=$'\n'
    fi
    block+="$line"
  done < "$snippet_file"

  if [[ -n "$block" && "$block" == "$prefix"* ]]; then
    typeset -g suggestion="$block"
  fi
}

typeset -ga ZSH_AUTOSUGGEST_STRATEGY=(history snippets completion)
ZSH_AUTOSUGGEST_HISTORY_IGNORE='?(#c100,)'

_source_first_readable \
  /usr/share/zsh/site-functions/zsh-autosuggestions.zsh \
  /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh \
  >/dev/null 2>&1

# override syntax highlight color
typeset -gA ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[comment]='fg=#6c7ea6'

if [[ -o interactive && -n $TMUX ]]; then
  function exit {
    if (( $# == 0 )); then
      builtin exit 0
    else
      builtin exit "$@"
    fi
  }
fi

# tmux
if [[ -z "$TMUX" && -n "$PS1" ]]; then
    tmux attach || tmux new
fi

# zsh-syntax-highlighting should stay last.
_source_first_readable \
  /usr/share/zsh/site-functions/zsh-syntax-highlighting.zsh \
  /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh \
  >/dev/null 2>&1
